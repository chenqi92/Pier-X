# Normalize all text files to LF in the repo, regardless of OS
* text=auto eol=lf

# Explicit text types
*.cpp     text eol=lf
*.h       text eol=lf
*.qml     text eol=lf
*.qmldir  text eol=lf
*.rs      text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.cmake   text eol=lf
*.txt     text eol=lf
*.json    text eol=lf
*.sh      text eol=lf

# Binaries
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.icns    binary
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
*.dmg     binary
*.zip     binary
