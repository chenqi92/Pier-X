<?xml version="1.0" encoding="utf-8"?>
<!--
  Pier-X Appcast Feed
  ────────────────────
  Both Sparkle (macOS) and WinSparkle (Windows) read this file to
  determine whether a newer version is available.

  CI should:
    1. Copy this template
    2. Replace version, date, URL, length, and signature
    3. Upload to https://releases.kkape.com/pier-x/appcast.xml

  Signature: use Sparkle's `generate_appcast` tool for EdDSA signing.
  The public key goes into Info.plist (SUPublicEDKey) for macOS and
  is embedded in the WinSparkle DSA verification flow for Windows.
-->
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Pier-X Updates</title>
    <link>https://github.com/chenqi92/Pier-X</link>
    <description>Latest versions of Pier-X</description>
    <language>en</language>

    <!-- macOS release -->
    <item>
      <title>Version 0.1.0</title>
      <pubDate>Sat, 12 Apr 2026 00:00:00 +0000</pubDate>
      <sparkle:version>010</sparkle:version>
      <sparkle:shortVersionString>0.1.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <h2>What's New</h2>
        <ul>
          <li>Initial public release</li>
        </ul>
      ]]></description>
      <enclosure
        url="https://releases.kkape.com/pier-x/Pier-X-0.1.0.dmg"
        type="application/octet-stream"
        sparkle:os="macos"
        sparkle:edSignature="PLACEHOLDER_ED_SIGNATURE"
        length="0"/>
    </item>

    <!-- Windows release -->
    <item>
      <title>Version 0.1.0</title>
      <pubDate>Sat, 12 Apr 2026 00:00:00 +0000</pubDate>
      <sparkle:version>0.1.0</sparkle:version>
      <sparkle:shortVersionString>0.1.0</sparkle:shortVersionString>
      <description><![CDATA[
        <h2>What's New</h2>
        <ul>
          <li>Initial public release</li>
        </ul>
      ]]></description>
      <enclosure
        url="https://releases.kkape.com/pier-x/Pier-X-0.1.0-setup.msi"
        type="application/octet-stream"
        sparkle:os="windows-x64"
        sparkle:edSignature="PLACEHOLDER_ED_SIGNATURE"
        length="0"/>
    </item>

  </channel>
</rss>
