<?xml version="1.0" encoding="UTF-8"?>
<!--
  pier-x.wxs — WiX v5 installer definition for Pier-X (Windows).

  Build:
    wix build packaging/pier-x.wxs -o pier-x.msi \
      -d Version=0.1.0 -d SourceDir=dist

  Prerequisites:
    dotnet tool install --global wix
    wix extension add --global WixToolset.UI.wixext
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Pier-X"
           Manufacturer="kkape"
           Version="$(var.Version)"
           UpgradeCode="A7E3F1B2-8C4D-4E5F-9A1B-2C3D4E5F6A7B"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage=
      "A newer version of Pier-X is already installed." />

    <!-- Minimal UI with license + progress -->
    <ui:WixUI Id="WixUI_Minimal" />

    <!-- ─── Directory layout ──────────────────────────── -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Pier-X">
        <Component Id="MainExecutable" Guid="*">
          <File Source="$(var.SourceDir)\pier-x.exe" KeyPath="yes" />
        </Component>

        <!-- All Qt DLLs + QML plugins deployed by windeployqt.
             HarvestDirectory would be cleaner for CI; for now
             we use a wildcard component group that the build
             script populates. -->
        <Component Id="QtRuntime" Guid="*">
          <!-- Placeholder: windeployqt copies these into SourceDir -->
          <!-- The actual file list is generated by the CI script -->
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- ─── Start Menu shortcut ───────────────────────── -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut Id="PierXShortcut"
                  Name="Pier-X"
                  Target="[INSTALLFOLDER]pier-x.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Description="Cross-platform terminal management" />
        <RegistryValue Root="HKCU"
                       Key="Software\kkape\Pier-X"
                       Name="StartMenuShortcut"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- ─── Features ──────────────────────────────────── -->
    <Feature Id="Complete" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="QtRuntime" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>
</Wix>
