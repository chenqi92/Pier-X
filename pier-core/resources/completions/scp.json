  "subcommands": [],
  "options": [
    {
      "flag": "-r",
      "i18n": {
        "en": "Recursively copy entire directories",
        "zh-CN": "递归复制整个目录"
      }
    },
    {
      "flag": "-P PORT",
      "i18n": {
