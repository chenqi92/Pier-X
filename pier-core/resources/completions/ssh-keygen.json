    },
    {
      "flag": "-s CA_KEY",
      "i18n": {
        "en": "Sign public keys using CA_KEY",
        "zh-CN": "用 CA 签发公钥"
      }
    },
    {
      "flag": "-I IDENTITY",
      "i18n": {
        "en": "Specify key identity (when signing)",
        "zh-CN": "签发时指定身份"
      }
    },
    {
      "flag": "-V VALIDITY",
      "i18n": {
        "en": "Specify validity interval (when signing)",
        "zh-CN": "签发时设置有效期"
      }
    },
    {
      "flag": "-Y FUNCTION",
      "i18n": {
        "en": "Functions related to signing data",
        "zh-CN": "签名相关功能（sign / verify 等）"
      }
    },
    {
      "flag": "-n PRINCIPAL",
      "i18n": {
        "en": "List of principals included in cert",
