{
  "schema_version": 1,
  "command": "ssh-keygen",
  "tool_version": "",
  "source": "bundled-seed",
  "import_method": "hand-curated",
  "import_date": "2026-04-26",
  "subcommands": [],
  "options": [
    {
      "flag": "-t TYPE",
      "i18n": {
        "en": "Key type (rsa / ed25519 / ecdsa / dsa)",
        "zh-CN": "密钥类型（rsa / ed25519 / ecdsa）"
      }
    },
    {
      "flag": "-b BITS",
      "i18n": {
        "en": "Number of bits in the key",
        "zh-CN": "密钥位数"
      }
    },
    {
      "flag": "-C COMMENT",
      "i18n": {
        "en": "Provide a new comment",
        "zh-CN": "为密钥添加注释（通常是邮箱）"
      }
    },
    {
      "flag": "-f FILE",
      "i18n": {
        "en": "Specify the filename of the key file",
        "zh-CN": "指定密钥文件路径"
      }
    },
    {
      "flag": "-N PASSPHRASE",
      "i18n": {
        "en": "Provide new passphrase",
        "zh-CN": "新密钥的口令"
      }
    },
    {
      "flag": "-P PASSPHRASE",
      "i18n": {
        "en": "Provide old passphrase (when changing)",
        "zh-CN": "原密钥的口令（改密时）"
      }
    },
    {
      "flag": "-p",
      "i18n": {
        "en": "Change the passphrase of a private key",
        "zh-CN": "修改私钥口令"
      }
