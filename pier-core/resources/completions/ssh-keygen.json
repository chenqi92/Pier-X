    {
      "flag": "-H",
      "i18n": {
        "en": "Hash known_hosts file",
        "zh-CN": "将 known_hosts 主机名哈希"
      }
    },
    {
      "flag": "-A",
      "i18n": {
        "en": "Generate host keys for all default key types",
        "zh-CN": "为所有默认类型生成主机密钥"
