    },
    {
      "flag": "-z SERIAL",
      "i18n": {
        "en": "Specify the certificate serial number",
        "zh-CN": "证书序号"
      }
    },
    {
      "flag": "-q",
      "i18n": {
        "en": "Quiet output",
        "zh-CN": "静默"
      }
    },
    {
      "flag": "-v",
      "i18n": {
        "en": "Verbose mode",
        "zh-CN": "详细模式"
      }
    },
    {
      "flag": "-K",
      "i18n": {
        "en": "Download resident keys from a security key",
        "zh-CN": "从安全令牌下载常驻密钥"
      }
    },
    {
      "flag": "-k",
      "i18n": {
        "en": "Generate a KRL or test against KRL",
        "zh-CN": "生成或测试 KRL"
      }
    },
    {
      "flag": "--help",
      "i18n": {
        "en": "Display help",
        "zh-CN": "显示帮助"
      }
    }
  ]
}
